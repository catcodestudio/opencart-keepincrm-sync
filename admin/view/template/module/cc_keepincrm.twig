{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-sd" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <button type="button" id="btn-log" class="btn btn-info"><i class="fa-solid fa-list"></i> {{ text_log_link }}</button>
        <a href="{{ back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div id="alert-sd"></div>
    <div id="log-panel" class="mb-3"></div>

    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-sd" action="{{ save }}" method="post">

          <fieldset>
            <legend>{{ text_connection }}</legend>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_status }}</label>
              <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="module_cc_keepincrm_status" value="0"/>
                <input type="checkbox" name="module_cc_keepincrm_status" value="1" class="form-check-input"{{ status == '1' ? ' checked' : '' }}/>
              </div></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_api_key }}</label>
              <div class="col-sm-9">
                <input type="password" name="module_cc_keepincrm_api_key" value="" class="form-control" placeholder="{{ api_key_set ? text_secret_set : '' }}" autocomplete="new-password"/>
                <div class="form-text">{{ help_api_key }}</div>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-sm-9 offset-sm-3">
                <button type="button" id="btn-test" class="btn btn-outline-primary"><i class="fa-solid fa-plug"></i> {{ button_test }}</button>
                <span id="test-result" class="ms-2"></span>
              </div>
            </div>
          </fieldset>

          <fieldset>
            <legend>{{ text_general }}</legend>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_send_on }}</label>
              <div class="col-sm-9"><select name="module_cc_keepincrm_send_on" class="form-select" style="max-width:280px">
                <option value="create"{{ send_on == 'create' ? ' selected' : '' }}>{{ text_on_create }}</option>
                <option value="status"{{ send_on == 'status' ? ' selected' : '' }}>{{ text_on_status }}</option>
              </select><div class="form-text">{{ help_send_on }}</div></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_trigger }}</label>
              <div class="col-sm-9"><select name="module_cc_keepincrm_trigger_status" class="form-select" style="max-width:280px">
                {% for s in order_statuses %}
                <option value="{{ s.order_status_id }}"{{ trigger_status == s.order_status_id ? ' selected' : '' }}>{{ s.name }}</option>
                {% endfor %}
              </select></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_skip_zero }}</label>
              <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="module_cc_keepincrm_skip_zero" value="0"/>
                <input type="checkbox" name="module_cc_keepincrm_skip_zero" value="1" class="form-check-input"{{ skip_zero == '1' ? ' checked' : '' }}/>
              </div></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_include_ship }}</label>
              <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="module_cc_keepincrm_include_ship" value="0"/>
                <input type="checkbox" name="module_cc_keepincrm_include_ship" value="1" class="form-check-input"{{ include_ship == '1' ? ' checked' : '' }}/>
              </div></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_retry }}</label>
              <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="module_cc_keepincrm_retry_enabled" value="0"/>
                <input type="checkbox" name="module_cc_keepincrm_retry_enabled" value="1" class="form-check-input"{{ retry_enabled == '1' ? ' checked' : '' }}/>
              </div></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_max_attempts }}</label>
              <div class="col-sm-9"><input type="number" min="1" max="50" name="module_cc_keepincrm_max_attempts" value="{{ max_attempts }}" class="form-control" style="max-width:120px"/></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_source }}</label>
              <div class="col-sm-9"><input type="text" name="module_cc_keepincrm_source_label" value="{{ source_label }}" class="form-control" style="max-width:280px"/></div>
            </div>
          </fieldset>

          <fieldset>
            <legend>{{ text_routing }}</legend>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_funnel_id }}</label>
              <div class="col-sm-9"><input type="number" min="0" step="1" name="module_cc_keepincrm_funnel_id" value="{{ funnel_id ?: '' }}" class="form-control" style="max-width:160px"/></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_stage_id }}</label>
              <div class="col-sm-9"><input type="number" min="0" step="1" name="module_cc_keepincrm_stage_id" value="{{ stage_id ?: '' }}" class="form-control" style="max-width:160px"/></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_source_id }}</label>
              <div class="col-sm-9"><input type="number" min="0" step="1" name="module_cc_keepincrm_source_id" value="{{ source_id ?: '' }}" class="form-control" style="max-width:160px"/></div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-3 col-form-label">{{ entry_responsible_id }}</label>
              <div class="col-sm-9"><input type="number" min="0" step="1" name="module_cc_keepincrm_main_responsible_id" value="{{ main_responsible_id ?: '' }}" class="form-control" style="max-width:160px"/><div class="form-text">{{ help_routing }}</div></div>
            </div>
          </fieldset>

        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// Twig html-escapes controller URLs (& -> &amp;); fine in href but breaks
// fetch() targets (user_token lost -> login page instead of JSON).
function ccKcUrl(s) { return s.replace(/&amp;/g, '&'); }

document.getElementById('form-sd').addEventListener('submit', function(e) {
  e.preventDefault();
  var alertBox = document.getElementById('alert-sd');
  fetch(ccKcUrl('{{ save }}'), { method: 'POST', body: new FormData(this) })
    .then(function(r){ return r.json(); })
    .then(function(json){
      if (json.error) { alertBox.innerHTML = '<div class="alert alert-danger">' + json.error + '</div>'; }
      else if (json.success) { alertBox.innerHTML = '<div class="alert alert-success">' + json.success + '</div>'; }
      window.scrollTo(0, 0);
    });
});

document.getElementById('btn-test').addEventListener('click', function(){
  var out = document.getElementById('test-result');
  out.innerHTML = '<span class="text-muted">…</span>';
  var fd = new FormData();
  fd.append('api_key', document.querySelector('[name="module_cc_keepincrm_api_key"]').value);
  fetch(ccKcUrl('{{ test }}'), { method: 'POST', body: fd })
    .then(function(r){ return r.json(); })
    .then(function(json){
      if (json.ok) { out.innerHTML = '<span class="text-success">{{ text_test_ok }}</span>'; }
      else { out.innerHTML = '<span class="text-danger">' + (json.error || 'Error') + '</span>'; }
    });
});

document.getElementById('btn-log').addEventListener('click', function(){
  var panel = document.getElementById('log-panel');
  fetch(ccKcUrl('{{ log }}')).then(function(r){ return r.text(); }).then(function(html){ panel.innerHTML = html; });
});
</script>
{{ footer }}
